        <!-- =========================================================== -->
        <!-- CAPÍTULO 1 — CONSULTAS                                       -->
        <!-- =========================================================== -->

        <record id="practice_01_01" model="clinic.practice">
            <field name="faco_code">01.01</field>
            <field name="name">Examen, fichado, diagnóstico y plan de tratamiento</field>
            <field name="short_name">Examen y diagnóstico</field>
            <field name="slots_required">2</field>
            <field name="specialty_id" ref="specialty_odontologia"/>
            <field name="description">Examen clínico completo, fichado, diagnóstico y plan de tratamiento. Se reconoce 1 vez al año si la realiza el mismo prestador.</field>
        </record>

        <record id="practice_01_04" model="clinic.practice">
            <field name="faco_code">01.04</field>
            <field name="name">Consulta de urgencia</field>
            <field name="short_name">Urgencia</field>
            <field name="slots_required">2</field>
            <field name="specialty_id" ref="specialty_odontologia"/>
            <field name="description">Atención sin turno previo que resuelve una demanda espontánea. Aplica a prestaciones que no constituyen paso intermedio de tratamiento. Ej: pericoronaritis, estomatitis, alveolitis.</field>
        </record>

