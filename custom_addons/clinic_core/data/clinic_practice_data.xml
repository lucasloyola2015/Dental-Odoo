            <field name="slots_required">2</field>
            <field name="specialty_id" ref="specialty_odontologia"/>
            <field name="description">Obturación que abarca una cara de la pieza (oclusal, gingival, mesial o distal). Garantía: 2 años por el mismo profesional.</field>
        </record>

        <record id="practice_02_02" model="clinic.practice">
            <field name="faco_code">02.02</field>
            <field name="name">Restauración compuesta. Todo tipo de material</field>
