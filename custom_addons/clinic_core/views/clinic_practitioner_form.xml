<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================ -->
        <!-- Simplified Practitioner FORM (own, not inherited)             -->
        <!-- ============================================================ -->
        <record id="view_clinic_practitioner_form" model="ir.ui.view">
            <field name="name">clinic.practitioner.form</field>
            <field name="model">hr.employee</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <form string="Profesional">
                    <field name="active" invisible="1"/>
                    <field name="is_clinic_practitioner" invisible="1"/>
                    <widget name="web_ribbon" title="Archivado" bg_color="text-bg-danger" invisible="active"/>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_appointments" type="object" class="oe_stat_button" icon="fa-calendar"
                                    invisible="not appointment_count">
                                <field name="appointment_count" widget="statinfo" string="Turnos"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <label for="name" string="Nombre"/>
                            <h1>
                                <field name="name" placeholder="Nombre Apellido" required="1"/>
                            </h1>
                            <h3 class="text-muted" invisible="not medical_license and not vat">
                                <field name="medical_license" readonly="1" nolabel="1" class="oe_inline" invisible="not medical_license"/>
                                <span invisible="not vat or not medical_license"> · </span>
                                <span invisible="not vat">DNI <field name="vat" readonly="1" nolabel="1" class="oe_inline"/></span>
                            </h3>
                        </div>
                        <notebook>
                            <page string="Datos personales" name="personal_data">
                                <group>
                                    <field name="vat" string="DNI" placeholder="30234567"/>
                                    <field name="work_email" widget="email" string="Email"/>
                                    <field name="work_phone" widget="phone" string="Teléfono"/>
                                </group>
                            </page>
                            <page string="Datos profesionales" name="professional_data">
                                <group>
                                    <field name="medical_license" placeholder="MP 12345"/>
                                    <field name="specialty_main_id" options="{'no_create': True}"/>
                                    <field name="specialty_ids" widget="many2many_tags" options="{'no_create': True}"/>
                                    <field name="default_appointment_duration_minutes" string="Duración default (min)"/>
                                    <field name="slots_buffer_post_minutes" string="Buffer entre turnos (min)"/>
                                </group>
                            </page>
                            <page string="Sedes y horarios" name="roles">
                                <field name="practitioner_role_ids" context="{'default_employee_id': id}">
                                    <list editable="bottom">
                                        <field name="location_id" options="{'no_create': True}"/>
                                        <button name="action_open_schedule" type="object"
                                                string="📅 Editar horarios"
                                                class="btn-link"
                                                help="Abrir editor de grilla rutinaria, días extras y días excluidos."/>
                                        <field name="allowed_route_ids" column_invisible="True"/>
                                        <field name="routing_mode" column_invisible="True"/>
                                        <field name="assigned_route_id" string="Modalidad"
                                               options="{'no_create': True, 'no_open': True}"
                                               domain="[('id', 'in', allowed_route_ids)]"/>
                                        <field name="available_insurance_ids" column_invisible="True"/>
                                        <field name="excluded_insurance_ids" widget="many2many_tags"
                                               options="{'no_create': True}"
                                               string="OS que NO acepta"
                                               domain="[('id', 'in', available_insurance_ids)]"
                                               readonly="routing_mode != 'association'"/>
                                        <field name="particular_percentage" string="% Colegio" widget="percentage"/>
                                        <field name="calendar_color" widget="color" optional="hide"/>
                                        <field name="valid_from" optional="hide"/>
                                        <field name="valid_to" string="Vigencia hasta"/>
                                        <field name="resource_calendar_id" optional="hide"/>
                                        <field name="active" widget="boolean_toggle"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Prácticas que realiza" name="practices">
                                <field name="practitioner_practice_ids" context="{'default_employee_id': id}">
                                    <list editable="bottom">
                                        <field name="location_id" options="{'no_create': True}"/>
                                        <field name="practice_id" options="{'no_create': True}"/>
                                        <field name="can_perform" widget="boolean_toggle"/>
                                        <field name="default_duration_minutes" string="Duración (min)"/>
                                        <field name="active" widget="boolean_toggle"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Notas" name="notes">
                                <field name="clinic_observations" nolabel="1"
                                       placeholder="Particularidades del profesional. Ej: 'Solo atiende ortodoncia bajo microscopio.', 'No atiende ancianos por preferencia.'"/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ============================================================ -->
        <!-- Simplified Practitioner LIST                                  -->
        <!-- ============================================================ -->
        <record id="view_clinic_practitioner_list" model="ir.ui.view">
            <field name="name">clinic.practitioner.list</field>
            <field name="model">hr.employee</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <list string="Profesionales">
                    <field name="name"/>
                    <field name="medical_license" string="Matrícula"/>
                    <field name="specialty_main_id" string="Especialidad"/>
                    <field name="work_phone" string="Teléfono" optional="show"/>
                    <field name="work_email" string="Email" optional="hide"/>
                    <field name="appointment_count" string="Turnos" optional="show"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <!-- ============================================================ -->
        <!-- Action override: force our simplified views                  -->
        <!-- ============================================================ -->
        <record id="action_clinic_practitioner" model="ir.actions.act_window">
            <field name="name">Profesionales</field>
            <field name="res_model">hr.employee</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('is_clinic_practitioner', '=', True)]</field>
            <field name="context">{'default_is_clinic_practitioner': True}</field>
            <field name="view_ids" eval="[
                (5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('view_clinic_practitioner_list')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('view_clinic_practitioner_form')}),
            ]"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Cargá el primer profesional de la clínica.
                </p>
                <p>
                    Campos mínimos: Nombre, DNI, Matrícula y Especialidad. En las pestañas cargás
                    sus clínicas (con horario) y las prácticas que realiza con precios particulares.
                </p>
            </field>
        </record>

    </data>
</odoo>
