<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_clinic_specialty_list" model="ir.ui.view">
            <field name="name">clinic.specialty.list</field>
            <field name="model">clinic.specialty</field>
            <field name="arch" type="xml">
                <list string="Especialidades" multi_edit="1">
                    <field name="code"/>
                    <field name="complete_name" string="Especialidad"/>
                    <field name="parent_id" optional="hide"/>
                    <field name="default_appointment_duration_minutes" string="Duración default (min)"/>
                    <field name="company_id" groups="base.group_multi_company" optional="show"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <record id="view_clinic_specialty_form" model="ir.ui.view">
            <field name="name">clinic.specialty.form</field>
            <field name="model">clinic.specialty</field>
            <field name="arch" type="xml">
                <form string="Especialidad">
                    <sheet>
                        <widget name="web_ribbon" title="Archivada" bg_color="text-bg-danger" invisible="active"/>
                        <field name="active" invisible="1"/>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="Ej: Odontopediatría"/>
                            </h1>
                            <div class="text-muted" invisible="not parent_id">
                                Sub-especialidad de <field name="parent_id" readonly="1" nolabel="1" class="oe_inline"/>
                            </div>
                        </div>
                        <group>
                            <group>
                                <field name="code" placeholder="Ej: ODONTO_PED"/>
                                <field name="parent_id" options="{'no_create_edit': True}"/>
                                <field name="company_id" options="{'no_create': True}" groups="base.group_multi_company"/>
                            </group>
                            <group>
                                <field name="default_appointment_duration_minutes"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Sub-especialidades" name="children" invisible="not child_ids and id">
                                <field name="child_ids" nolabel="1">
                                    <list editable="bottom">
                                        <field name="code"/>
                                        <field name="name"/>
                                        <field name="default_appointment_duration_minutes" string="Duración (min)"/>
                                        <field name="active" widget="boolean_toggle"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_clinic_specialty_search" model="ir.ui.view">
            <field name="name">clinic.specialty.search</field>
            <field name="model">clinic.specialty</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="parent_id"/>
                    <filter name="filter_roots" string="Solo raíces" domain="[('parent_id', '=', False)]"/>
                    <separator/>
                    <filter name="filter_archived" string="Archivadas" domain="[('active', '=', False)]"/>
                    <separator/>
                    <group>
                        <filter name="group_by_parent" string="Especialidad raíz" domain="[]" context="{'group_by': 'parent_id'}"/>
                        <filter name="group_by_company" string="Compañía" domain="[]" context="{'group_by': 'company_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_clinic_specialty" model="ir.actions.act_window">
            <field name="name">Especialidades</field>
            <field name="res_model">clinic.specialty</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_clinic_specialty_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Cargá la primera especialidad de la clínica.
                </p>
                <p>
                    Una especialidad agrupa a profesionales (Odontología, Cardiología, etc.) y puede tener
                    sub-especialidades (Ortodoncia, Endodoncia, Odontopediatría). Define la duración por defecto
                    de turnos cuando el profesional no establece la suya.
                </p>
            </field>
        </record>

        <menuitem
            id="menu_clinic_specialty"
            name="Especialidades"
            parent="menu_clinic_config_structure"
            action="action_clinic_specialty"
            sequence="20"/>

    </data>
</odoo>
