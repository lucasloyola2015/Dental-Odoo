<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_clinic_billing_route_list" model="ir.ui.view">
            <field name="name">clinic.billing.route.list</field>
            <field name="model">clinic.billing.route</field>
            <field name="arch" type="xml">
                <list string="Vías de facturación">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="requires_membership" widget="boolean_toggle"/>
                    <field name="company_id" groups="base.group_multi_company" optional="show"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <record id="view_clinic_billing_route_form" model="ir.ui.view">
            <field name="name">clinic.billing.route.form</field>
            <field name="model">clinic.billing.route</field>
            <field name="arch" type="xml">
                <form string="Vía de facturación">
                    <sheet>
                        <widget name="web_ribbon" title="Archivada" bg_color="text-bg-danger" invisible="active"/>
                        <field name="active" invisible="1"/>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="Ej: AOSS"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="code" placeholder="Ej: AOSS"/>
                                <field name="requires_membership"/>
                                <field name="company_id" options="{'no_create': True}" groups="base.group_multi_company"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Observaciones" name="observations">
                                <field name="observations" nolabel="1" placeholder="Particularidades de la vía..."/>
                            </page>
                            <page string="Plantilla PDF" name="pdf_template">
                                <group>
                                    <field name="pdf_template" filename="pdf_template_filename"/>
                                    <field name="pdf_template_filename" invisible="1"/>
                                </group>
                                <separator string="Campos a sobreimprimir"/>
                                <div class="text-muted mb-2">
                                    Coordenadas en puntos PDF. Origen <strong>esquina superior izquierda</strong>;
                                    Y crece hacia abajo. El editor visual con drag-and-drop está en la siguiente
                                    iteración — por ahora, ajustá los valores acá y descargá el F1 desde un turno
                                    para ver el resultado.
                                </div>
                                <field name="pdf_field_ids" nolabel="1">
                                    <list editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="field_key"/>
                                        <field name="label"/>
                                        <field name="x"/>
                                        <field name="y"/>
                                        <field name="font_size"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_clinic_billing_route" model="ir.actions.act_window">
            <field name="name">Vías de facturación</field>
            <field name="res_model">clinic.billing.route</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem
            id="menu_clinic_billing_route"
            name="Vías de facturación"
            parent="menu_clinic_config_insurance"
            action="action_clinic_billing_route"
            sequence="20"/>

    </data>
</odoo>
