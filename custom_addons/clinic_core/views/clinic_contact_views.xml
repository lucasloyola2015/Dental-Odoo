<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_clinic_contact_list" model="ir.ui.view">
            <field name="name">clinic.contact.list</field>
            <field name="model">clinic.contact</field>
            <field name="arch" type="xml">
                <list string="Canales de contacto">
                    <field name="type"/>
                    <field name="value_display" string="Valor"/>
                    <field name="value" optional="hide"/>
                    <field name="verified" widget="boolean_toggle"/>
                    <field name="company_id" groups="base.group_multi_company" optional="hide"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <record id="view_clinic_contact_form" model="ir.ui.view">
            <field name="name">clinic.contact.form</field>
            <field name="model">clinic.contact</field>
            <field name="arch" type="xml">
                <form string="Canal de contacto">
                    <sheet>
                        <widget name="web_ribbon" title="Archivado" bg_color="text-bg-danger" invisible="active"/>
                        <field name="active" invisible="1"/>
                        <div class="oe_title">
                            <label for="value"/>
                            <h1>
                                <field name="value" placeholder="+5493411234567"/>
                            </h1>
                            <div class="text-muted">
                                <field name="value_display" readonly="1" nolabel="1"/>
                            </div>
                        </div>
                        <group>
                            <group>
                                <field name="type"/>
                                <field name="verified" widget="boolean_toggle"/>
                                <field name="verified_at" invisible="not verified"/>
                                <field name="company_id" options="{'no_create': True}" groups="base.group_multi_company"/>
                            </group>
                            <group>
                                <field name="start_date"/>
                                <field name="end_date"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Personas vinculadas" name="people">
                                <field name="person_contact_ids" nolabel="1">
                                    <list editable="bottom">
                                        <field name="partner_id"/>
                                        <field name="role"/>
                                        <field name="is_primary" widget="boolean_toggle"/>
                                        <field name="start_date" optional="hide"/>
                                        <field name="end_date" optional="hide"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Notas" name="notes">
                                <field name="notes" nolabel="1" placeholder="Notas sobre este canal..."/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_clinic_contact_search" model="ir.ui.view">
            <field name="name">clinic.contact.search</field>
            <field name="model">clinic.contact</field>
            <field name="arch" type="xml">
                <search>
                    <field name="value"/>
                    <field name="type"/>
                    <separator/>
                    <filter name="filter_whatsapp" string="WhatsApp" domain="[('type', '=', 'whatsapp')]"/>
                    <filter name="filter_email" string="Email" domain="[('type', '=', 'email')]"/>
                    <filter name="filter_phone" string="Teléfono" domain="[('type', 'in', ['phone_mobile', 'phone_fixed'])]"/>
                    <separator/>
                    <filter name="filter_verified" string="Verificados" domain="[('verified', '=', True)]"/>
                    <filter name="filter_archived" string="Archivados" domain="[('active', '=', False)]"/>
                    <group>
                        <filter name="group_by_type" string="Tipo" domain="[]" context="{'group_by': 'type'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_clinic_contact" model="ir.actions.act_window">
            <field name="name">Canales de contacto</field>
            <field name="res_model">clinic.contact</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_clinic_contact_search"/>
        </record>

        <menuitem
            id="menu_clinic_contact"
            name="Canales de contacto"
            parent="menu_clinic_configuration"
            action="action_clinic_contact"
            sequence="20"/>

    </data>
</odoo>
