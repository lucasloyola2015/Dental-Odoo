<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_clinic_patient_list" model="ir.ui.view">
            <field name="name">clinic.patient.list</field>
            <field name="model">clinic.patient</field>
            <field name="arch" type="xml">
                <list string="Pacientes">
                    <field name="medical_history_number" string="N° HC"/>
                    <field name="name"/>
                    <field name="vat" string="DNI"/>
                    <field name="birthdate"/>
                    <field name="age" optional="show"/>
                    <field name="phone" optional="show"/>
                    <field name="email" optional="hide"/>
                    <field name="start_date" string="Paciente desde" optional="hide"/>
                    <field name="company_id" groups="base.group_multi_company" optional="hide"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <record id="view_clinic_patient_form" model="ir.ui.view">
            <field name="name">clinic.patient.form</field>
            <field name="model">clinic.patient</field>
            <field name="arch" type="xml">
                <form string="Paciente">
                    <sheet>
                        <widget name="web_ribbon" title="Archivado" bg_color="text-bg-danger" invisible="active"/>
                        <field name="active" invisible="1"/>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_partner" type="object" class="oe_stat_button" icon="fa-address-card">
                                <div class="o_stat_info">
                                    <span class="o_stat_text">Ver ficha</span>
                                    <span class="o_stat_text">de Persona</span>
                                </div>
                            </button>
                            <button name="action_view_appointments" type="object" class="oe_stat_button" icon="fa-calendar"
                                    invisible="not appointment_count">
                                <field name="appointment_count" widget="statinfo" string="Turnos"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="Nombre Apellido" required="1"/>
                            </h1>
                            <div class="text-muted small" invisible="not start_date">
                                Paciente desde <field name="start_date" readonly="1" nolabel="1" class="oe_inline"/>
                            </div>
                        </div>
                        <group>
                            <group string="Identificación">
                                <field name="partner_id" string="Persona"
                                       options="{'no_create_edit': True}"
                                       help="Si la persona ya existe (otro paciente, profesional, titular de OS), seleccionala para reusar sus datos. Si la dejás vacía y cargás el nombre arriba, se crea una nueva."/>
                                <field name="medical_history_number" readonly="1"/>
                                <field name="vat" string="DNI" placeholder="30234567"/>
                                <field name="birthdate"/>
                                <field name="age" readonly="1"/>
                                <field name="gender"/>
                            </group>
                            <group string="Contacto">
                                <field name="use_external_contact"/>
                                <field name="phone" widget="phone" invisible="use_external_contact"/>
                                <field name="email" widget="email" invisible="use_external_contact"/>
                                <field name="external_contact_summary" readonly="1" widget="text" invisible="not use_external_contact" nolabel="1" colspan="2"/>
                            </group>
                        </group>
                        <group>
                            <group string="Gestión">
                                <field name="company_id" options="{'no_create': True}" groups="base.group_multi_company"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Vínculos" name="links">
                                <p class="text-muted">
                                    Cada vínculo se crea automáticamente en ambas direcciones (si Pedro es padre de Sofía, Sofía será hija de Pedro). Las casillas indican lo que la otra persona puede hacer sobre este paciente.
                                </p>
                                <field name="clinic_link_as_b_ids" nolabel="1" context="{'default_partner_b_id': partner_id}">
                                    <list editable="bottom">
                                        <field name="partner_a_id" string="Persona" required="1"/>
                                        <field name="relationship_type" string="es"/>
                                        <field name="is_legal_guardian" widget="boolean_toggle" optional="show"/>
                                        <field name="can_consent" widget="boolean_toggle" optional="show"/>
                                        <field name="can_be_contacted" widget="boolean_toggle" optional="show"/>
                                        <field name="notes" optional="hide"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Coberturas" name="coverage">
                                <field name="coverage_ids" context="{'default_patient_id': id}">
                                    <list editable="bottom">
                                        <field name="health_insurance_id" required="1"/>
                                        <field name="member_number"/>
                                        <field name="plan" optional="show"/>
                                        <field name="is_holder" widget="boolean_toggle"/>
                                        <field name="holder_partner_id" invisible="is_holder" required="not is_holder"/>
                                        <field name="os_relationship"/>
                                        <field name="is_primary" widget="boolean_toggle"/>
                                        <field name="order" string="Prio" optional="hide"/>
                                        <field name="valid_from" optional="hide"/>
                                        <field name="valid_to" optional="hide"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Notas" name="notes">
                                <group>
                                    <field name="secretariat_notes" placeholder="Notas operativas de la secretaría..." nolabel="1"/>
                                </group>
                                <group>
                                    <field name="clinic_observations" placeholder="Observaciones generales de la persona..." nolabel="1"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_clinic_patient_search" model="ir.ui.view">
            <field name="name">clinic.patient.search</field>
            <field name="model">clinic.patient</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name" string="Nombre / DNI / HC" filter_domain="['|', '|', ('name', 'ilike', self), ('vat', 'ilike', self), ('medical_history_number', 'ilike', self)]"/>
                    <field name="medical_history_number" string="N° HC"/>
                    <field name="phone"/>
                    <field name="email"/>
                    <separator/>
                    <filter name="filter_archived" string="Archivados" domain="[('active', '=', False)]"/>
                    <separator/>
                    <group>
                        <filter name="group_by_company" string="Compañía" domain="[]" context="{'group_by': 'company_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_clinic_patient" model="ir.actions.act_window">
            <field name="name">Pacientes</field>
            <field name="res_model">clinic.patient</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_clinic_patient_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Cargá el primer paciente.
                </p>
                <p>
                    Cada paciente se vincula a una persona física (res.partner). Si la persona ya existe
                    en el sistema (porque es contacto, titular de obra social, etc.), reusala. La historia
                    clínica pertenece a la clínica/compañía en la que se atiende.
                </p>
            </field>
        </record>

        <menuitem
            id="menu_clinic_patient"
            name="Pacientes"
            parent="menu_clinic_root"
            action="action_clinic_patient"
            sequence="10"/>

    </data>
</odoo>
