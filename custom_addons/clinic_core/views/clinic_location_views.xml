<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================ -->
        <!-- List                                                          -->
        <!-- ============================================================ -->
        <record id="view_clinic_location_list" model="ir.ui.view">
            <field name="name">clinic.location.list</field>
            <field name="model">clinic.location</field>
            <field name="arch" type="xml">
                <list string="Sucursales">
                    <field name="sequence" widget="handle"/>
                    <field name="code"/>
                    <field name="name"/>
                    <field name="city" optional="show"/>
                    <field name="billing_route_id" string="Asociación"/>
                    <field name="phone" optional="show"/>
                    <field name="email" optional="hide"/>
                    <field name="company_id" groups="base.group_multi_company" optional="hide"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <!-- ============================================================ -->
        <!-- Form                                                          -->
        <!-- ============================================================ -->
        <record id="view_clinic_location_form" model="ir.ui.view">
            <field name="name">clinic.location.form</field>
            <field name="model">clinic.location</field>
            <field name="arch" type="xml">
                <form string="Sucursal">
                    <sheet>
                        <field name="active" invisible="1"/>
                        <widget name="web_ribbon" title="Archivada" bg_color="text-bg-danger" invisible="active"/>
                        <div class="oe_title">
                            <label for="name" string="Sucursal"/>
                            <h1>
                                <field name="name" placeholder="Ej: Roldán Centro"/>
                            </h1>
                            <h3 class="text-muted">
                                <field name="code" placeholder="ROL" class="oe_inline"/>
                            </h3>
                        </div>
                        <group>
                            <group string="Identificación">
                                <field name="company_id" options="{'no_create': True}" groups="base.group_multi_company"/>
                                <field name="billing_route_id" options="{'no_create': True}"/>
                                <field name="sequence"/>
                            </group>
                            <group string="Contacto">
                                <field name="phone" widget="phone"/>
                                <field name="email" widget="email"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Dirección" name="address">
                                <group>
                                    <group>
                                        <field name="street" placeholder="Calle y número"/>
                                        <field name="street2" placeholder="Piso, depto, referencias"/>
                                        <field name="city" placeholder="Ciudad"/>
                                    </group>
                                    <group>
                                        <field name="state_id" options="{'no_create': True}"/>
                                        <field name="zip"/>
                                        <field name="country_id" options="{'no_create': True}"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Notas" name="notes">
                                <field name="notes" nolabel="1"
                                       placeholder="Particularidades operativas de la sede. Ej: 'Solo atiende mañanas', 'Comparte cocina con vecino'."/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ============================================================ -->
        <!-- Search                                                        -->
        <!-- ============================================================ -->
        <record id="view_clinic_location_search" model="ir.ui.view">
            <field name="name">clinic.location.search</field>
            <field name="model">clinic.location</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="city"/>
                    <field name="billing_route_id"/>
                    <separator/>
                    <filter name="filter_archived" string="Archivadas" domain="[('active', '=', False)]"/>
                    <group>
                        <filter name="group_by_company" string="Compañía" domain="[]"
                                context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                        <filter name="group_by_route" string="Asociación" domain="[]"
                                context="{'group_by': 'billing_route_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ============================================================ -->
        <!-- Action + Menu                                                 -->
        <!-- ============================================================ -->
        <record id="action_clinic_location" model="ir.actions.act_window">
            <field name="name">Sucursales</field>
            <field name="res_model">clinic.location</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_clinic_location_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Cargá la primera sucursal de la clínica.
                </p>
                <p>
                    Cada sucursal pertenece a una compañía y trabaja bajo una asociación
                    regional (AOSS, ASOR, etc.) que define sus tarifas. Profesionales,
                    horarios y turnos se asignan a sucursales.
                </p>
            </field>
        </record>

        <menuitem
            id="menu_clinic_location"
            name="Sucursales"
            parent="menu_clinic_configuration"
            action="action_clinic_location"
            sequence="10"/>

    </data>
</odoo>
