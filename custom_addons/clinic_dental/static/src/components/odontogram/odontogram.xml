<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="clinic_dental.OdontogramField">
        <div class="o_odontogram_widget">
            <div class="o_odontogram_chart">
                <svg viewBox="0 0 760 240" class="o_odontogram_svg" xmlns="http://www.w3.org/2000/svg">
                    <line x1="380" y1="0" x2="380" y2="240" stroke="#666" stroke-width="1.5" stroke-dasharray="4 3"/>
                    <line x1="0" y1="120" x2="760" y2="120" stroke="#666" stroke-width="1.5"/>

                    <t t-foreach="positionedTeeth" t-as="t" t-key="t.fdi">
                        <g t-att-transform="t.transform">
                            <text t-att-x="18" t-att-y="t.labelY" text-anchor="middle" font-size="10" fill="#333">
                                <t t-esc="t.fdi"/>
                            </text>
                            <path t-att-d="topPath" t-att-fill="t.fillTop" stroke="#333" stroke-width="0.8"
                                  style="cursor: pointer;"
                                  t-on-click="(ev) =&gt; this.onSurfaceClick(ev, t.fdi, t.surfaceTop)">
                                <title><t t-esc="t.tooltipTop"/></title>
                            </path>
                            <path t-att-d="rightPath" t-att-fill="t.fillRight" stroke="#333" stroke-width="0.8"
                                  style="cursor: pointer;"
                                  t-on-click="(ev) =&gt; this.onSurfaceClick(ev, t.fdi, t.surfaceRight)">
                                <title><t t-esc="t.tooltipRight"/></title>
                            </path>
                            <path t-att-d="bottomPath" t-att-fill="t.fillBottom" stroke="#333" stroke-width="0.8"
                                  style="cursor: pointer;"
                                  t-on-click="(ev) =&gt; this.onSurfaceClick(ev, t.fdi, t.surfaceBottom)">
                                <title><t t-esc="t.tooltipBottom"/></title>
                            </path>
                            <path t-att-d="leftPath" t-att-fill="t.fillLeft" stroke="#333" stroke-width="0.8"
                                  style="cursor: pointer;"
                                  t-on-click="(ev) =&gt; this.onSurfaceClick(ev, t.fdi, t.surfaceLeft)">
                                <title><t t-esc="t.tooltipLeft"/></title>
                            </path>
                            <rect x="12" y="12" width="12" height="12" t-att-fill="t.fillCenter" stroke="#333" stroke-width="0.8"
                                  style="cursor: pointer;"
                                  t-on-click="(ev) =&gt; this.onSurfaceClick(ev, t.fdi, 'occlusal')">
                                <title><t t-esc="t.tooltipCenter"/></title>
                            </rect>
                        </g>
                    </t>
                </svg>
            </div>

            <div class="o_odontogram_legend">
                <strong>Leyenda:</strong>
                <span class="badge bg-danger me-1">Rojo</span> Previsto / observado.
                <span class="badge bg-primary me-1 ms-2">Azul</span> Realizado / existente.
                <span class="text-muted ms-3">Blanco = sin registro. Click en cualquier superficie para editar.</span>
            </div>
        </div>
    </t>

</templates>
